#!/bin/bash

# Gemini Shell Wrapper
# Enters the isolated Podman environment shell.

CONTAINER="gemini-sandbox-container"
PROJECTS_DIR="/home/raytiong/projects"

# If we are already in the sandbox, just open a new bash shell
if [ "$GEMINI_SANDBOX" = "1" ] || [ "$GEMINI_CLI" = "1" ] || [ -f /.dockerenv ] || [ -f /run/.containerenv ]; then
    exec /bin/bash
fi

# Detect Podman path
PODMAN=$(which podman 2>/dev/null || echo "/opt/podman/bin/podman")

# Ensure the container is running (delegates to gemini-isolate for logic)
# We run a no-op command to trigger the startup logic in gemini-isolate
"$(dirname "$0")/gemini-isolate" --version > /dev/null

# Enter the shell
exec $PODMAN exec -it -w $PROJECTS_DIR $CONTAINER /bin/bash
