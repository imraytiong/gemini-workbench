#!/bin/bash

# Gemini CLI Isolate Wrapper (Podman Container)
# High security: Full Ubuntu container isolation.

MACHINE="podman-machine-default"
CONTAINER="gemini-sandbox-container"
PODMAN="/opt/podman/bin/podman"

# Ensure Podman machine and container are running
STATUS=$($PODMAN machine inspect $MACHINE --format "{{.State}}" 2>/dev/null)
if [ "$STATUS" != "running" ]; then
    echo "Starting Podman machine ($MACHINE)..."
    $PODMAN machine start
fi

if ! $PODMAN ps --format "{{.Names}}" | grep -q "^$CONTAINER$"; then
    echo "Starting $CONTAINER..."
    $PODMAN start $CONTAINER
fi

# Check for existing sessions inside the container
HAS_SESSIONS=$($PODMAN exec $CONTAINER gemini --list-sessions 2>/dev/null | grep -c "\.")

# Only prompt if sessions exist and no --resume flag is present
if [ $HAS_SESSIONS -gt 0 ] && [[ ! "$*" == *"--resume"* ]]; then
    echo -n "Would you like to resume the last session? [Y/n] "
    read -r response
    response=${response:-Y} # Default to Y if Enter is pressed

    if [[ "$response" =~ ^[Yy]$ ]]; then
        set -- "--resume" "latest" "$@"
    fi
fi

# Run the command inside the Linux container
$PODMAN exec -it -w /home/raytiong/projects $CONTAINER gemini "$@"
