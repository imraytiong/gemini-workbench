#!/bin/bash

# Gemini CLI Isolate Wrapper (Podman Container)
# High security: Full Ubuntu container isolation.

IMAGE_NAME="gemini-sandbox"
CONTAINER="gemini-sandbox-container"

# Dynamically set the workspace root relative to this script
BIN_DIR=$(cd "$(dirname "$0")" && pwd)
WORKBENCH_ROOT=$(dirname "$BIN_DIR")
PROJECTS_DIR=$(dirname "$WORKBENCH_ROOT")

# Detect host user and determine consistent container paths
HOST_USER=$(whoami)
CONTAINER_HOME="/home/$HOST_USER"
CONTAINER_PROJECTS="$CONTAINER_HOME/projects"
CONTAINER_GEMINI_HOME="$CONTAINER_HOME/.gemini"

# Detect if we are ALREADY in a sandboxed session to avoid recursion errors
if [ "$GEMINI_SANDBOX" = "1" ] || [ "$GEMINI_CLI" = "1" ] || [ -f /.dockerenv ] || [ -f /run/.containerenv ]; then
    # We are already in an isolated session or we are the Gemini CLI agent itself.
    # If no arguments, run gemini. If arguments, check if it's a known command or fallback to gemini.
    if [ $# -eq 0 ]; then
        exec gemini
    else
        case "$1" in
            python3|node|npm|git|bash|sh|ls|cat|rm|mkdir|cp|mv|pytest)
                exec "$@"
                ;;
            /*|./*|../*)
                exec "$@"
                ;;
            *)
                exec gemini "$@"
                ;;
        esac
    fi
fi

# Detect Podman path
PODMAN=$(which podman 2>/dev/null || echo "/opt/podman/bin/podman")

# 1. Ensure Podman machine is running (on macOS/Windows)
if [[ "$OSTYPE" == "darwin"* ]]; then
    MACHINE="podman-machine-default"
    STATUS=$($PODMAN machine inspect $MACHINE --format "{{.State}}" 2>/dev/null)
    if [ "$STATUS" != "running" ]; then
        echo "Starting Podman machine ($MACHINE)..."
        $PODMAN machine start
    fi
fi

# 2. Ensure the container exists
if ! $PODMAN ps -a --format "{{.Names}}" | grep -q "^$CONTAINER$"; then
    echo "Creating $CONTAINER from $IMAGE_NAME..."
    
    # Check if image exists
    if ! $PODMAN image exists $IMAGE_NAME; then
        echo "Error: Image $IMAGE_NAME not found. Run 'bin/build-sandbox' first."
        exit 1
    fi

    # Create the container but don't start it yet
    # We mount ~/.gemini to share session history and settings
    $PODMAN create --name $CONTAINER \
        --userns=keep-id \
        -v "$PROJECTS_DIR:$CONTAINER_PROJECTS" \
        -v "$HOME/.gemini:$CONTAINER_GEMINI_HOME" \
        -w "$CONTAINER_PROJECTS" \
        -e GEMINI_CLI=1 \
        -e SANDBOX=podman \
        -e GMAIL_USER="$GMAIL_USER" \
        -e GMAIL_PASS="$GMAIL_PASS" \
        -it $IMAGE_NAME
fi

# 3. Ensure the container is running
if ! $PODMAN ps --format "{{.Names}}" | grep -q "^$CONTAINER$"; then
    echo "Starting $CONTAINER..."
    $PODMAN start $CONTAINER
fi

# 4. Map the current working directory from host to container
# If we are in the projects directory, translate the path.
HOST_CWD=$(pwd)
if [[ "$HOST_CWD" == "$PROJECTS_DIR"* ]]; then
    # Strip the host prefix and append to container prefix
    REL_PATH=${HOST_CWD#"$PROJECTS_DIR"}
    CONTAINER_CWD="$CONTAINER_PROJECTS$REL_PATH"
else
    # Fallback to projects root if outside the mounted path
    CONTAINER_CWD="$CONTAINER_PROJECTS"
fi

# 5. Run the command inside the Linux container
export COLORTERM=truecolor

# Dry-run support for testing
if [ "$DRY_RUN" = "1" ]; then
    CMD_PREFIX="echo"
else
    CMD_PREFIX="exec"
fi

# Default to running 'gemini' if no arguments are provided, otherwise run the provided command
if [ $# -eq 0 ]; then
    $CMD_PREFIX $PODMAN exec -it -e COLORTERM=truecolor -e SANDBOX=podman -w "$CONTAINER_CWD" $CONTAINER gemini
else
    # Check if the first argument is an absolute path or a known command in common bin dirs
    # If not, it might be a sub-command for gemini, so we default to gemini "$@"
    case "$1" in
        python3|node|npm|git|bash|sh|ls|cat|rm|mkdir|cp|mv|pytest)
            $CMD_PREFIX $PODMAN exec -it -e COLORTERM=truecolor -e SANDBOX=podman -w "$CONTAINER_CWD" $CONTAINER "$@"
            ;;
        /*|./*|../*)
            $CMD_PREFIX $PODMAN exec -it -e COLORTERM=truecolor -e SANDBOX=podman -w "$CONTAINER_CWD" $CONTAINER "$@"
            ;;
        *)
            $CMD_PREFIX $PODMAN exec -it -e COLORTERM=truecolor -e SANDBOX=podman -w "$CONTAINER_CWD" $CONTAINER gemini "$@"
            ;;
    esac
fi

