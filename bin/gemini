#!/bin/bash

# Gemini CLI Wrapper (Seatbelt Native Sandbox)
# Default security: macOS Seatbelt (sandbox-exec)

SB_PROFILE="$HOME/projects/gemini-workbench/config/gemini.sb"
GEMINI_BIN="/Users/raytiong/.nvm/versions/node/v24.11.0/bin/gemini"

if [ ! -f "$SB_PROFILE" ]; then
    echo "Error: Seatbelt profile not found at $SB_PROFILE"
    exit 1
fi

# Detect if we are ALREADY in a sandboxed session to avoid recursion errors
if [ "$GEMINI_SANDBOX" = "1" ]; then
    echo "Using existing sandbox environment."
    "$GEMINI_BIN" "$@"
    exit $?
fi

# 1. Check if any sessions exist for this project
# We use a temporary non-sandboxed check or just trust the binary
# Actually, for the check we can just run it without sandbox or with it if it's not recursive
HAS_SESSIONS=$("$GEMINI_BIN" --list-sessions 2>/dev/null | grep -c "\.")

# 2. Only prompt if sessions exist and no --resume flag is already provided
if [ $HAS_SESSIONS -gt 0 ] && [[ ! "$*" == *"--resume"* ]]; then
    echo -n "Would you like to resume the last session? [Y/n] "
    read -r response
    response=${response:-Y} # Default to Y if Enter is pressed

    if [[ "$response" =~ ^[Yy]$ ]]; then
        set -- "--resume" "latest" "$@"
    fi
fi

# 3. Run with sandbox-exec
# -D HOME=$HOME sets the HOME parameter used in the .sb file
export GEMINI_SANDBOX=1
/usr/bin/sandbox-exec -f "$SB_PROFILE" -D HOME="$HOME" "$GEMINI_BIN" "$@"
