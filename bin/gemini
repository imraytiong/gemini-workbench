#!/bin/bash

# Gemini CLI Wrapper (Seatbelt Native Sandbox)
# Default security: macOS Seatbelt (sandbox-exec)

SB_PROFILE="$HOME/projects/gemini-workbench/config/gemini.sb"
GEMINI_BIN="/Users/raytiong/.nvm/versions/node/v24.11.0/bin/gemini"

if [ ! -f "$SB_PROFILE" ]; then
    echo "Error: Seatbelt profile not found at $SB_PROFILE"
    exit 1
fi

# Run with sandbox-exec
# -D HOME=$HOME sets the HOME parameter used in the .sb file
/usr/bin/sandbox-exec -f "$SB_PROFILE" -D HOME="$HOME" "$GEMINI_BIN" "$@"
