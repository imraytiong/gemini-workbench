#!/bin/bash

# Gemini Workbench: Default Wrapper
# Directs all workbench sessions to the isolated Podman environment.

# 1. Handle Sandbox Recursion
if [ "$GEMINI_SANDBOX" = "1" ] || [ "$GEMINI_CLI" = "1" ] || [ -f /.dockerenv ] || [ -f /run/.containerenv ]; then
    export SANDBOX="podman"
    exec gemini "$@"
fi

# 4. Delegate to gemini-isolate
exec "$(dirname "$0")/gemini-isolate" "$@"
