#!/bin/bash

# Podman Sandbox Reset
# Forcefully cleans up and restarts the Podman machine to resolve hangs.

set -e

# Detect Podman path
PODMAN=$(which podman 2>/dev/null || echo "/opt/podman/bin/podman")
MACHINE="podman-machine-default"

# Helper function to prevent hangs
run_with_timeout() {
    local timeout=$1
    shift
    "$@" &
    local pid=$!
    local count=0
    while kill -0 $pid 2>/dev/null; do
        if [ $count -ge $timeout ]; then
            kill -9 $pid 2>/dev/null
            return 124
        fi
        sleep 1
        count=$((count+1))
    done
    wait $pid
    return $?
}

echo "Starting Podman recovery sequence..."

# 1. Attempt Soft Reset
echo "Attempting soft stop (10s timeout)..."
if run_with_timeout 10 "$PODMAN" machine stop "$MACHINE"; then
    echo "Soft stop successful."
else
    echo "Soft stop failed or timed out. Initiating hard reset..."
    
    # 2. Hard Reset: Kill orphaned processes (macOS specific)
    if [[ "$OSTYPE" == "darwin"* ]]; then
        echo "Cleaning up orphaned VM processes (gvproxy, qemu, vfkit)..."
        
        # We use 'pkill -9' for immediate termination of these specific processes
        # gvproxy: Podman's networking
        # qemu-system-aarch64 / vfkit: The actual VM process
        pkill -9 gvproxy || true
        pkill -9 qemu-system-aarch64 || true
        pkill -9 vfkit || true
        
        # Clean up stale sockets/locks if they exist in common locations
        rm -f "$HOME/.config/containers/podman/machine/qemu/$MACHINE.sock" 2>/dev/null || true
    fi

    # Final attempt to stop after force killing orphans
    run_with_timeout 5 "$PODMAN" machine stop "$MACHINE" || true
fi

# 3. Restart the Machine
echo "Starting Podman machine ($MACHINE)..."
if run_with_timeout 45 "$PODMAN" machine start "$MACHINE"; then
    echo "✅ Podman machine is back online."
else
    echo "❌ Error: Failed to restart Podman machine after recovery."
    exit 1
fi
