FROM ubuntu:24.04

# Avoid prompts
ENV DEBIAN_FRONTEND=noninteractive
ENV GEMINI_SANDBOX=1
ENV SANDBOX=podman
ENV COLORTERM=truecolor
ENV TERM=xterm-256color

# Update and install core tools
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    sudo \
    ca-certificates \
    python3 \
    python3-pip \
    python3-venv \
    build-essential \
    ncurses-term \
    libsecret-1-0 \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22.x
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Create user with matching host UID/GID
ARG USERNAME
ARG USER_UID=501
ARG USER_GID=20

RUN (groupadd --gid $USER_GID $USERNAME || groupmod -n $USERNAME $(getent group $USER_GID | cut -d: -f1)) \
    && (useradd --uid $USER_UID --gid $USER_GID -m $USERNAME || usermod -l $USERNAME $(getent passwd $USER_UID | cut -d: -f1)) \
    && echo $USERNAME ALL=\(root\) NOPASSWD:ALL > /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME

# Set working directory
WORKDIR /home/${USERNAME}/projects

# Install Gemini CLI globally
RUN npm install -g @google/gemini-cli

USER $USERNAME

# Set entrypoint to bash
ENTRYPOINT ["/bin/bash"]
